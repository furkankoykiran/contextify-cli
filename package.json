{
  "name": "@furkankoykiran/contextify-cli",
  "version": "0.6.0",
  "description": "Open-source CLI for Claude Code: capture sessions, ship transcripts to your memory pipeline, and synthesize Claude-ready prompts.",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "telemetry",
    "transcript",
    "memory",
    "prompt",
    "prompt-engineering",
    "context-engineering",
    "cli",
    "agent",
    "agentic-ai",
    "developer-tools"
  ],
  "homepage": "https://contextify.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/furkankoykiran/contextify-cli.git"
  },
  "bugs": {
    "url": "https://github.com/furkankoykiran/contextify-cli/issues"
  },
  "author": "Furkan Köykıran",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "contextify": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/commands/hooks.d.ts",
      "import": "./dist/commands/hooks.js"
    },
    "./transcript": {
      "types": "./dist/transcript.d.ts",
      "import": "./dist/transcript.js"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "import": "./dist/identity.js"
    },
    "./install-hooks": {
      "types": "./dist/commands/install-hooks.d.ts",
      "import": "./dist/commands/install-hooks.js"
    },
    "./install": {
      "types": "./dist/commands/install.d.ts",
      "import": "./dist/commands/install.js"
    },
    "./prompt": {
      "types": "./dist/commands/prompt.d.ts",
      "import": "./dist/commands/prompt.js"
    }
  },
  "files": [
    "dist",
    "src/hooks"
  ],
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "start": "node ./dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,yaml}\"",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "typescript": "5.5.4",
    "vitest": "2.1.8"
  }
}
