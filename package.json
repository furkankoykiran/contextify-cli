{
  "name": "@gbrain/cli",
  "version": "0.1.0",
  "private": true,
  "description": "gBrain telemetry CLI — shadows terminal sessions, ships logs to the webhook",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "gbrain": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@gbrain/eslint-config": "workspace:*",
    "@gbrain/tsconfig": "workspace:*",
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "typescript": "5.5.4",
    "vitest": "2.1.8"
  }
}
